# Database (default: local SQLite file)
DATABASE_URL=sqlite:///./data/faceace.db

# Default LLM profile (seeded into llm_profiles on first start if DB is empty)
# Any OpenAI-compatible endpoint works: DeepSeek / SiliconFlow / OpenAI / 通义 / Ollama
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# CORS (comma-separated origins of the frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
